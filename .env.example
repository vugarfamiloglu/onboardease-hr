# ── OnboardEase HR — environment ───────────────────────────────────────────
# Copy to .env. Everything runs locally out of the box; the AWS values are only
# needed when you switch document storage to S3 + KMS.

SECRET_KEY=change-me-to-a-long-random-secret
DATABASE_URL=sqlite:///data/onboardease.db

# ── Document storage ────────────────────────────────────────────────────────
# "local" = encrypted filesystem (envelope encryption, the default).
# "s3"    = AWS S3 object storage with a KMS-wrapped data key per file.
STORAGE_BACKEND=local

# For STORAGE_BACKEND=s3 (AWS credentials come from the standard chain:
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars, profile or instance role).
S3_BUCKET=
AWS_REGION=us-east-1
KMS_KEY_ID=

# Local envelope master key (base64 of 32 bytes). Auto-generated to
# data/.master-key on first run if left blank. NEVER commit the real key.
MASTER_KEY=

# ── Reminders / mail ────────────────────────────────────────────────────────
# "file" writes emails to data/outbox (no SMTP needed), "console" prints,
# "smtp" delivers for real.
MAIL_BACKEND=file
MAIL_FROM=hr@onboardease.test
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Seeded HR admin account
SEED_ADMIN_EMAIL=hr@onboardease.test
SEED_ADMIN_PASSWORD=onboard123
